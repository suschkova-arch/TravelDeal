# ============================================================
# TravelDeal — шаблон настроек
# Скопируйте этот файл в .env и впишите свои значения.
# Файл .env НИКОГДА не загружайте на GitHub (он в .gitignore)!
# ============================================================

# Порт сервера
PORT=3001

# Amadeus API (бесплатная регистрация: https://developers.amadeus.com)
AMADEUS_API_KEY=ваш_ключ_amadeus
AMADEUS_API_SECRET=ваш_секрет_amadeus
AMADEUS_HOSTNAME=test

# Email для заявок
EMAIL_USER=ваша_почта@yandex.ru
EMAIL_PASS=пароль_приложения_из_настроек_почты
EMAIL_TO=почта_для_заявок@mail.ru

# База данных (если используется)
DATABASE_URL=postgresql://user:password@localhost:5432/traveldeal
